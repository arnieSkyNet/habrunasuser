#!/bin/bash
#LOGFILE="/home/pi/log/launchprog.log"
LOGFILE="/home/pi/log/arnie.log"
SCRIPT_NAME=$(basename "$0")
VER=0.05
# Prevent recursive invocation as early as possible
if [[ "$LAUNCHPROG_ACTIVE" == "1" ]]; then
    echo "[$(date +%T)  $SCRIPT_NAME v$VER] $(id -un) Re-entry blocked"  >> "$LOGFILE"
    exit 0
fi
# Set the active flag to block further invocations
export LAUNCHPROG_ACTIVE=1

# Debugging: Track entry and user ID
echo "==============================================" >> "$LOGFILE"
echo "[$(date +%T) $SCRIPT_NAME v$VER] $(id -un) Entering script LAUNCHPROG_ACTIVE=$LAUNCHPROG_ACTIVE" >> "$LOGFILE"

# Existing PATH settings
#export PATH=/usr/local/bin:/usr/bin:/bin:/home/pi/sbin

# Ensure SSH_AUTH_SOCK is available, start agent if needed
if [ -z "$SSH_AUTH_SOCK" ] && [ "$(id -u)" -ne 0 ]; then
    eval $(ssh-agent)
    echo "[$(date +%T) $SCRIPT_NAME v$VER] $(id -un) Ensured SSH_AUTH_SOCK is available, start agent if needed LAUNCHPROG_ACTIVE=$LAUNCHPROG_ACTIVE" >> "$LOGFILE"
fi

if [ "$(id -u)" -eq 0 ]; then
    echo "[$(date +%T) $SCRIPT_NAME v$VER] $(id -un) running as root LAUNCHPROG_ACTIVE=$LAUNCHPROG_ACTIVE" >> "$LOGFILE"
    # Script is running as root
    if [ $# -eq 0 ]; then
          echo "[$(date +%T) $SCRIPT_NAME v$VER] root:$(id -un): No parameters passed to launchprog. exiting" >> "$LOGFILE"
          exit 0
    fi
    export DISPLAY=:0
    DEBUG_MODE=false
    if [[ "$1" == "-d" ]]; then
        DEBUG_MODE=true
        shift  # Remove -d from the arguments list
    fi
    # Build the environment variable to be passed to the 'pi' user
    habridgessh="$0 $@"
    # Remove /home/pi/sbin/launchprog from habridgessh
    habridgessh="${habridgessh//\/home\/pi\/sbin\/launchprog/}"
    echo "[$(date +%T) $SCRIPT_NAME v$VER] root:$(id -un) Setting habridgessh for user pi: $habridgessh" >> "$LOGFILE"
    if $DEBUG_MODE; then
        echo "Debug mode enabled." >> "$LOGFILE"
        lxterminal --display=:0 -e "sudo -u pi env HOME=/home/pi habridgessh=\"$habridgessh\" bash -c '/home/pi/sbin/launchprog'"
    else
        # Normal execution
        NO_AT_BRIDGE=1 xfce4-terminal --display=:0 -e "bash --norc -c 'sudo -u pi env HOME=/home/pi habridgessh=\"$habridgessh\" bash -i -c /home/pi/sbin/launchprog'"
        ##NO_AT_BRIDGE=1 xfce4-terminal --display=:0 -e "bash --norc -c 'sudo -u pi env HOME=/home/pi LAUNCHPROG_ACTIVE= habridgessh=\"$habridgessh\" bash -i -c /home/pi/sbin/launchprog'"
    fi
    exit 0
else
    # Script is running as pi
    if [ -z "$habridgessh" ]; then
        habridgessh="rootsentnothing"
        echo "[$(date +%T) $SCRIPT_NAME v$VER] $(id -un) pi: habridgessh empty Setting habridgessh rootsentnothing: $habridgessh and exiting" >> "$LOGFILE"
        exit 0
    fi
    command2do="$habridgessh"
    echo "[$(date +%T) $SCRIPT_NAME v$VER] $(id -un) Executing final command: $command2do" >> "$LOGFILE"
    unset habridgessh
    bash -c "exec $command2do"
    echo "[$(date +%T) $SCRIPT_NAME v$VER] $(id -un) Exiting script" >> "$LOGFILE"
    echo "----------------------------------------------" >> "$LOGFILE"
    echo " " >> "$LOGFILE"
fi
exit 0
